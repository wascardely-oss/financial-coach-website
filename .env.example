# Stripe Configuration
# Get these from your Stripe Dashboard (https://dashboard.stripe.com/apikeys)
# Make sure both keys are from the same environment (both test or both live)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here

# Base URL for Stripe redirects
NEXT_PUBLIC_BASE_URL=https://financial-coach-website.onrender.com

# Google Analytics
# Obtén tu ID en: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email Service (opcional)
# Para integrar con Formspree, EmailJS, etc.
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
